{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/mcp/agent_skill_admission_receipt.schema.json",
  "title": "Agent Skill Admission Receipt v0.1",
  "description": "Receipt for admitting an agent skill into runtime use. Distinct from MCP tool admission — controls skill/repo instruction onboarding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "skill_name",
    "skill_source",
    "skill_version",
    "origin",
    "owner",
    "permission_model",
    "scope",
    "prompt_injection_risk_controls",
    "command_surface",
    "network_access",
    "filesystem_access",
    "secret_access",
    "review_outcome",
    "review_checklist",
    "reviewer",
    "evidence_pointers",
    "escalation_path",
    "do_not_infer",
    "timestamp"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0-candidate" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "skill_name": { "type": "string", "minLength": 1 },
    "skill_source": { "type": "string", "description": "Source path or URL of the skill." },
    "skill_version": { "type": "string" },
    "origin": { "type": "string", "enum": ["local", "fleet", "community", "unknown"] },
    "owner": { "type": "string" },
    "permission_model": { "type": "string", "enum": ["unrestricted", "scoped", "sandboxed", "gated", "unknown"] },
    "scope": { "type": "array", "items": { "type": "string" } },
    "prompt_injection_risk_controls": { "type": "array", "items": { "type": "string" } },
    "command_surface": { "type": "array", "items": { "type": "string" } },
    "network_access": { "type": "string", "enum": ["none", "outbound", "inbound", "bidirectional", "unknown"] },
    "filesystem_access": { "type": "string", "enum": ["none", "read", "write", "read_write", "unknown"] },
    "secret_access": { "type": "string", "enum": ["none", "read", "write", "read_write", "unknown"] },
    "review_outcome": { "type": "string", "enum": ["admit", "admit_with_scope", "quarantine", "reject", "unknown"] },
    "review_checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_verified",
        "permission_model_reviewed",
        "scope_bounded",
        "prompt_injection_risk_assessed",
        "command_surface_reviewed",
        "network_access_reviewed",
        "filesystem_access_reviewed",
        "secret_access_reviewed",
        "revocation_path_defined",
        "logging_enabled"
      ],
      "properties": {
        "source_verified": { "type": "boolean" },
        "permission_model_reviewed": { "type": "boolean" },
        "scope_bounded": { "type": "boolean" },
        "prompt_injection_risk_assessed": { "type": "boolean" },
        "command_surface_reviewed": { "type": "boolean" },
        "network_access_reviewed": { "type": "boolean" },
        "filesystem_access_reviewed": { "type": "boolean" },
        "secret_access_reviewed": { "type": "boolean" },
        "revocation_path_defined": { "type": "boolean" },
        "logging_enabled": { "type": "boolean" }
      }
    },
    "reviewer": { "type": "string" },
    "evidence_pointers": { "type": "array", "items": { "type": "string" } },
    "escalation_path": { "type": "string", "description": "Path for escalating unsafe or untrusted skill behavior." },
    "do_not_infer": { "type": "array", "items": { "type": "string" } },
    "timestamp": { "type": "string" }
  }
}
