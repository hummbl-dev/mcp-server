{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/mcp/dependency_update_receipt.schema.json",
  "title": "Dependency Update Receipt v0.1",
  "description": "Receipt for risk-ranking dependency update churn. Evidence-bounded — does not merge or block by itself.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "package_name",
    "current_version",
    "target_version",
    "update_source",
    "security_fix_claimed",
    "security_source",
    "runtime_surface",
    "breaking_change_risk",
    "tests_required",
    "tests_observed",
    "review_owner",
    "merge_recommendation",
    "residual_risk",
    "evidence_pointers",
    "do_not_infer",
    "timestamp"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0-candidate" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "package_name": { "type": "string", "minLength": 1 },
    "current_version": { "type": "string" },
    "target_version": { "type": "string" },
    "update_source": { "type": "string", "enum": ["dependabot", "renovate", "manual", "security_advisory", "unknown"] },
    "security_fix_claimed": { "type": "boolean" },
    "security_source": { "type": ["string", "null"] },
    "runtime_surface": { "type": "string", "enum": ["dev_dependency", "runtime_dependency", "build_tool", "type_definition", "unknown"] },
    "breaking_change_risk": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
    "tests_required": { "type": "boolean" },
    "tests_observed": { "type": "string", "enum": ["passed", "failed", "not_run", "unknown"] },
    "review_owner": { "type": "string" },
    "merge_recommendation": { "type": "string", "enum": ["merge", "hold", "quarantine", "unknown"] },
    "residual_risk": { "type": "array", "items": { "type": "string" } },
    "evidence_pointers": { "type": "array", "items": { "type": "string" } },
    "do_not_infer": { "type": "array", "items": { "type": "string" } },
    "timestamp": { "type": "string" }
  }
}
