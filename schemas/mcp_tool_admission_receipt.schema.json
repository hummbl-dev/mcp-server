{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/mcp/mcp_tool_admission_receipt.schema.json",
  "title": "MCP Tool Admission Receipt v0.1",
  "description": "Receipt for admitting an MCP tool into agent use. Admission is scoped and revocable, not permanent trust.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "tool_name",
    "server_name",
    "version_or_ref",
    "owner",
    "transport",
    "authentication_required",
    "authorization_model",
    "command_surface",
    "network_access",
    "filesystem_access",
    "secret_access",
    "sandbox_posture",
    "logging_and_receipts",
    "revocation_path",
    "known_risks",
    "allowed_scopes",
    "disabled_by_default_commands",
    "admission_decision",
    "reviewer",
    "evidence_pointers",
    "do_not_infer",
    "timestamp"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0-candidate" },
    "receipt_id": { "type": "string", "minLength": 1 },
    "tool_name": { "type": "string", "minLength": 1 },
    "server_name": { "type": "string", "minLength": 1 },
    "version_or_ref": { "type": "string" },
    "owner": { "type": "string" },
    "transport": { "type": "string", "enum": ["stdio", "http", "sse", "websocket", "custom"] },
    "authentication_required": { "type": "boolean" },
    "authorization_model": { "type": "string" },
    "command_surface": { "type": "array", "items": { "type": "string" } },
    "network_access": { "type": "string", "enum": ["none", "outbound", "inbound", "bidirectional"] },
    "filesystem_access": { "type": "string", "enum": ["none", "read", "write", "read_write"] },
    "secret_access": { "type": "string", "enum": ["none", "read", "write", "read_write"] },
    "sandbox_posture": { "type": "string", "enum": ["isolated", "containerized", "host", "unknown"] },
    "logging_and_receipts": { "type": "boolean" },
    "revocation_path": { "type": "string" },
    "known_risks": { "type": "array", "items": { "type": "string" } },
    "allowed_scopes": { "type": "array", "items": { "type": "string" } },
    "disabled_by_default_commands": { "type": "array", "items": { "type": "string" } },
    "admission_decision": { "type": "string", "enum": ["admit", "admit_with_scope", "quarantine", "reject", "unknown"] },
    "reviewer": { "type": "string" },
    "evidence_pointers": { "type": "array", "items": { "type": "string" } },
    "do_not_infer": { "type": "array", "items": { "type": "string" } },
    "timestamp": { "type": "string" }
  }
}
